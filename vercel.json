{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/index.js": {
      "includeFiles": "artifacts/api-server/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/artifacts/luffy-ai/$1"
    }
  ]
}