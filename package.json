{
  "name": "workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm install --no-frozen-lockfile", 
    "start": "node api/index.js",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "~5.4.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "express": "^4.19.0",
    "p-retry": "^8.0.0",
    "tsx": "^4.7.1"
  }
}